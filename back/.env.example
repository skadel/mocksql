# ============================================================
# back/.env.example — copier en back/.env et compléter
# ============================================================

# ------------------------------------------------------------
# Google Cloud
# ------------------------------------------------------------
PROJECT_ID=<votre-projet-gcp>
GOOGLE_CLOUD_PROJECT=<votre-projet-gcp>
GOOGLE_CLOUD_LOCATION=us-central1

# Optionnel : chemin vers un fichier service-account JSON
# (si absent, Application Default Credentials sont utilisées)
# GOOGLE_APPLICATION_CREDENTIALS=/chemin/vers/service_account.json

# ------------------------------------------------------------
# BigQuery (import de schémas uniquement — pas d'exécution)
# ------------------------------------------------------------
BQ_SCHEMA_BILLING_PROJECT=<votre-projet-gcp>
BQ_REGION=US
BQ_SANDBOX_MODE=true
BQ_TEST_DATASET=test_dataset

# ------------------------------------------------------------
# Modèles LLM (Vertex AI / Gemini)
# Nécessite le rôle roles/aiplatform.user sur votre projet GCP
# ------------------------------------------------------------
DEFAULT_MODEL_NAME=gemini-2.0-flash-lite
# SOLVER_MODEL=gemini-2.5-pro
# ROUTING_MODEL=gemini-2.0-flash-lite
# ANALYSIS_MODEL=gemini-2.0-flash-lite
# EXPLAIN_MODEL=gemini-2.0-flash-lite

# ------------------------------------------------------------
# Base de données — DuckDB local (aucune infrastructure requise)
# ------------------------------------------------------------
DUCKDB_PATH=data/mocksql.duckdb

# ------------------------------------------------------------
# Sécurité (sessions, API interne)
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------
SECRET_KEY=<cle-secrete-aleatoire>
API_SECRET_KEY=<cle-api-aleatoire>

# OAuth Google (optionnel — authentification utilisateurs)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------
# Retrieval / Littéraux
# ------------------------------------------------------------
RETRIEVAL_MODE=bm25
LITERALS_TABLE_NAME=lit

# ------------------------------------------------------------
# SQLMesh (optionnel)
# ------------------------------------------------------------
# SQLMESH_META_DB=sqlmeshconf

# ------------------------------------------------------------
# LangSmith (optionnel — tracing LangChain)
# https://smith.langchain.com/
# ------------------------------------------------------------
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=<votre-cle-langsmith>

# ------------------------------------------------------------
# CORS — URL du frontend (doit correspondre à l'origine React)
# ------------------------------------------------------------
FRONT_URL=http://127.0.0.1:3000

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_LEVEL=INFO
