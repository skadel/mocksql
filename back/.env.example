# ============================================================
# back/.env.example — développement backend depuis les sources
# ============================================================
# Les variables GCP (VERTEX_PROJECT, BQ_TEST_PROJECT…) ne vont
# pas ici : elles sont propres à chaque utilisateur et doivent
# être définies dans un .env à la racine du projet mocksql.
# Voir docs/quickstart.md → "Variables d'environnement".

# ------------------------------------------------------------
# Modèles LLM (Vertex AI / Gemini)
# ------------------------------------------------------------
# Modèle par défaut — gemini-2.5-flash recommandé (supporte le thinking).
# Alternatives : gemini-2.5-pro (meilleure qualité, plus lent),
#                gemini-2.0-flash-lite (plus rapide, sans thinking).
DEFAULT_MODEL_NAME=gemini-2.5-flash

# Timeout (secondes) par appel LLM — borne un modèle qui ne répond pas ou qui rumine
# (hang muet constaté sur un modèle preview). Défaut 300 ; 0 = illimité.
# Équivalent mocksql.yml : llm.timeout
#   LLM_TIMEOUT=300

# Renvoyer les résumés de thinking Gemini dans la réponse (rendus dans les dumps de
# prompt, section "### reasoning") — diagnostic d'un modèle qui rumine. Défaut false.
# Équivalent mocksql.yml : llm.include_thoughts
#   LLM_INCLUDE_THOUGHTS=true

# Mode thinking Gemini (facultatif — uniquement sur gemini-2.5-flash / gemini-2.5-pro).
# Sépare la réflexion interne du texte affiché à l'utilisateur.
# Deux options exclusives — choisir l'une ou l'autre :
#   LLM_THINKING_BUDGET=1024   # nombre de tokens de réflexion (0 = désactivé)
#   LLM_THINKING_LEVEL=low     # minimal | low | medium | high
# Équivalent via mocksql.yml :
#   llm:
#     thinking_budget: 1024
#     # ou
#     thinking_level: low

# Plafond de sécurité anti-rumination : quand NI thinking_budget NI thinking_level ne sont
# fixés, MockSQL borne le thinking à un budget par défaut DÉRIVÉ du timeout (il s'épuise
# dans la fenêtre → le modèle répond au lieu d'être tué en plein raisonnement). À 300 s de
# timeout il vaut 24 576 (plafond API Gemini 2.5). Surcharge explicite ci-dessous ; 0 = pas
# de plafond. Équivalent mocksql.yml : llm.thinking_safety_budget
#   LLM_THINKING_SAFETY_BUDGET=24576

# ------------------------------------------------------------
# LangSmith (optionnel — tracing LangChain)
# https://smith.langchain.com/
# ------------------------------------------------------------
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=<votre-cle-langsmith>

# ------------------------------------------------------------
# CORS — URL du frontend (doit correspondre à l'origine React)
# ------------------------------------------------------------
FRONT_URL=http://127.0.0.1:3000

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_LEVEL=INFO
