# ============================================================
# back/.env.example — copier en back/.env et compléter
# ============================================================

# ------------------------------------------------------------
# Google Cloud
# ------------------------------------------------------------
VERTEX_PROJECT=<votre-projet-gcp>
GOOGLE_CLOUD_PROJECT=<votre-projet-gcp>
GOOGLE_CLOUD_LOCATION=us-central1

# Optionnel : chemin vers un fichier service-account JSON
# (si absent, Application Default Credentials sont utilisées)
# GOOGLE_APPLICATION_CREDENTIALS=/chemin/vers/service_account.json

# ------------------------------------------------------------
# BigQuery (import de schémas uniquement — pas d'exécution)
# ------------------------------------------------------------
BQ_TEST_PROJECT=<votre-projet-gcp>

# ------------------------------------------------------------
# Modèles LLM (Vertex AI / Gemini)
# Nécessite le rôle roles/aiplatform.user sur votre projet GCP
# ------------------------------------------------------------
DEFAULT_MODEL_NAME=gemini-2.0-flash-lite

# ------------------------------------------------------------
# LangSmith (optionnel — tracing LangChain)
# https://smith.langchain.com/
# ------------------------------------------------------------
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=<votre-cle-langsmith>

# ------------------------------------------------------------
# CORS — URL du frontend (doit correspondre à l'origine React)
# ------------------------------------------------------------
FRONT_URL=http://127.0.0.1:3000

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_LEVEL=INFO
